# Copy this file to .env and fill in real values. .env is gitignored —
# never commit real secrets.

# Hugging Face Hub token, used by huggingface_hub.login() when pushing
# or pulling checkpoints (Task 2, Step 2.5). Get one at
# https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=

# Used by frontend/app.py to know where the backend API is running.
# Locally: http://localhost:8000
# Inside docker-compose: http://backend:8000 (set automatically there,
# this .env value is only used for non-Docker local runs)
BACKEND_URL=http://localhost:8000

# Logging verbosity for src/utils/logger.py-based logging.
LOG_LEVEL=INFO